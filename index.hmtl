<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Portal Espiritual</title>

  <style>
    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
      font-family:Arial, sans-serif;
    }

    body{
      background:#0f0f14;
      color:white;
      min-height:100vh;
    }

    header{
      padding:30px;
      text-align:center;
      background:linear-gradient(90deg,#6a11cb,#2575fc);
    }

    header h1{
      font-size:38px;
    }

    .tabs{
      display:flex;
      justify-content:center;
      flex-wrap:wrap;
      gap:10px;
      margin:30px 0;
    }

    .tab-btn{
      padding:14px 24px;
      border:none;
      border-radius:12px;
      cursor:pointer;
      background:#1d1d28;
      color:white;
      font-size:16px;
      transition:0.3s;
    }

    .tab-btn:hover{
      background:#6a11cb;
    }

    .tab-content{
      display:none;
      max-width:900px;
      margin:auto;
      background:#171720;
      padding:30px;
      border-radius:20px;
      margin-bottom:40px;
    }

    .active{
      display:block;
    }

    input, select{
      width:100%;
      padding:14px;
      border-radius:12px;
      border:none;
      margin-top:12px;
      margin-bottom:20px;
      background:#262636;
      color:white;
    }

    button{
      padding:14px 24px;
      border:none;
      border-radius:12px;
      cursor:pointer;
      background:#6a11cb;
      color:white;
      font-size:16px;
      transition:0.3s;
    }

    button:hover{
      background:#7d28eb;
    }

    .result{
      margin-top:30px;
      background:#222232;
      padding:20px;
      border-radius:15px;
      line-height:1.7;
    }

    .flashcard{
      background:#202030;
      padding:25px;
      border-radius:20px;
      margin-top:20px;
    }

    .question{
      font-size:22px;
      margin-bottom:20px;
    }

    .option{
      display:block;
      width:100%;
      text-align:left;
      padding:14px;
      margin-bottom:10px;
      background:#2d2d40;
      border-radius:12px;
      cursor:pointer;
      border:2px solid transparent;
    }

    .option:hover{
      border-color:#6a11cb;
    }

    canvas{
      margin-top:30px;
      background:white;
      border-radius:15px;
      padding:10px;
    }

    img{
      max-width:100%;
      border-radius:15px;
      margin-top:20px;
    }
  </style>
</head>

<body>

<header>
  <h1>Portal Espiritual ✨</h1>
  <p>Leitura de Mão • Numerologia • Arquétipos • Frequência Hz</p>
</header>

<div class="tabs">
  <button class="tab-btn" onclick="openTab('mao')">Leitura da Mão</button>
  <button class="tab-btn" onclick="openTab('numerologia')">Numerologia</button>
  <button class="tab-btn" onclick="openTab('arquetipo')">Arquétipo</button>
  <button class="tab-btn" onclick="openTab('frequencia')">Frequência Hz</button>
</div>

<!-- LEITURA DE MÃO -->
<div class="tab-content active" id="mao">

  <h2>Leitura de Mão ✋</h2>

  <input type="file" id="handUpload" accept="image/*"/>

  <button onclick="analisarMao()">Analisar Palma</button>

  <div id="maoResultado" class="result"></div>

</div>

<!-- NUMEROLOGIA -->
<div class="tab-content" id="numerologia">

  <h2>Numerologia 🔮</h2>

  <input type="text" id="nome" placeholder="Nome Completo"/>

  <input type="date" id="nascimento"/>

  <button onclick="gerarNumerologia()">Analisar Numerologia</button>

  <div id="numerologiaResultado" class="result"></div>

</div>

<!-- ARQUÉTIPO -->
<div class="tab-content" id="arquetipo">

  <h2>Quiz de Arquétipo 🧠</h2>

  <div id="quizContainer"></div>

</div>

<!-- FREQUÊNCIA -->
<div class="tab-content" id="frequencia">

  <h2>Frequência Energética Hz ⚡</h2>

  <div id="freqContainer"></div>

</div>

<script>

function openTab(tabId){

  const tabs = document.querySelectorAll('.tab-content');

  tabs.forEach(tab=>{
    tab.classList.remove('active');
  });

  document.getElementById(tabId).classList.add('active');
}

function analisarMao(){

  const file = document.getElementById('handUpload').files[0];

  if(!file){
    alert("Envie uma foto da mão.");
    return;
  }

  const reader = new FileReader();

  reader.onload = function(e){

    document.getElementById("maoResultado").innerHTML = `
      <img src="${e.target.result}">
      <h3>Resultado da Leitura</h3>

      <p>
      Sua linha da vida mostra forte energia emocional e conexão espiritual.
      A linha da mente demonstra criatividade e sensibilidade.
      A linha do coração revela intensidade amorosa e grande empatia.
      </p>

      <p>
      Você possui tendência ao crescimento espiritual,
      busca profunda por propósito e forte intuição.
      </p>
    `;
  }

  reader.readAsDataURL(file);
}

function gerarNumerologia(){

  const nome = document.getElementById("nome").value;
  const data = document.getElementById("nascimento").value;

  if(!nome || !data){
    alert("Preencha todos os campos.");
    return;
  }

  const numero = Math.floor(Math.random()*9)+1;

  document.getElementById("numerologiaResultado").innerHTML = `
    <h3>Número Principal: ${numero}</h3>

    <p>
    Sua vibração numerológica indica liderança,
    espiritualidade e grande capacidade de transformação.
    </p>

    <p>
    Você tende a atrair experiências importantes
    para crescimento pessoal e emocional.
    </p>

    <p>
    Existe forte conexão com propósito de vida,
    criatividade e expansão energética.
    </p>
  `;
}

const perguntasArqu = [

"Você prefere liderar ou observar?",
"Você age pela emoção ou lógica?",
"Você gosta de aventura?",
"Você busca reconhecimento?",
"Você prefere estabilidade?",
"Você se considera criativo?",
"Você gosta de ajudar pessoas?",
"Você toma decisões rápidas?",
"Você é mais reservado?",
"Você sonha grande?",
"Você gosta de chamar atenção?",
"Você prefere paz ou adrenalina?",
"Você acredita em espiritualidade?",
"Você gosta de trabalhar sozinho?",
"Você se adapta fácil?",
"Você se considera intenso?",
"Você gosta de explorar ideias?",
"Você é sentimental?",
"Você busca liberdade?",
"Você gosta de inovação?"

];

let atualArqu = 0;
let respostasArqu = [];

function mostrarPerguntaArqu(){

  if(atualArqu >= perguntasArqu.length){

    finalizarArqu();
    return;
  }

  document.getElementById("quizContainer").innerHTML = `

    <div class="flashcard">

      <div class="question">
      ${atualArqu+1}. ${perguntasArqu[atualArqu]}
      </div>

      <button class="option" onclick="responderArqu('A')">A) Muito</button>
      <button class="option" onclick="responderArqu('B')">B) Às vezes</button>
      <button class="option" onclick="responderArqu('C')">C) Pouco</button>
      <button class="option" onclick="responderArqu('D')">D) Nunca</button>

    </div>
  `;
}

function responderArqu(resp){

  respostasArqu.push(resp);
  atualArqu++;

  mostrarPerguntaArqu();
}

function finalizarArqu(){

  document.getElementById("quizContainer").innerHTML = `

    <div class="result">

      <h2>Seus Arquétipos</h2>

      <h3>1. O Sábio</h3>
      <p>
      Você busca conhecimento profundo,
      entendimento emocional e evolução constante.
      </p>

      <h3>2. O Governante</h3>
      <p>
      Possui tendência natural à liderança,
      responsabilidade e organização.
      </p>

      <h3>3. O Mago</h3>
      <p>
      Forte conexão espiritual,
      criatividade elevada e grande intuição.
      </p>

    </div>
  `;
}

mostrarPerguntaArqu();

const perguntasFreq = [

"Você sente paz frequentemente?",
"Você medita?",
"Você controla emoções?",
"Você pratica gratidão?",
"Você dorme bem?",
"Você se sente motivado?",
"Você evita conflitos?",
"Você se conecta com natureza?",
"Você sente ansiedade?",
"Você é otimista?",
"Você ajuda pessoas?",
"Você cuida da saúde?",
"Você possui equilíbrio emocional?",
"Você se sente leve?",
"Você acredita em si?",
"Você sente propósito?",
"Você possui disciplina?",
"Você consegue relaxar?",
"Você controla pensamentos negativos?",
"Você sente felicidade constante?"

];

let atualFreq = 0;
let respostasFreq = [];

function mostrarPerguntaFreq(){

  if(atualFreq >= perguntasFreq.length){

    finalizarFreq();
    return;
  }

  document.getElementById("freqContainer").innerHTML = `

    <div class="flashcard">

      <div class="question">
      ${atualFreq+1}. ${perguntasFreq[atualFreq]}
      </div>

      <button class="option" onclick="responderFreq(4)">A) Sempre</button>
      <button class="option" onclick="responderFreq(3)">B) Frequentemente</button>
      <button class="option" onclick="responderFreq(2)">C) Raramente</button>
      <button class="option" onclick="responderFreq(1)">D) Nunca</button>

    </div>
  `;
}

function responderFreq(valor){

  respostasFreq.push(valor);
  atualFreq++;

  mostrarPerguntaFreq();
}

function finalizarFreq(){

  let total = respostasFreq.reduce((a,b)=>a+b,0);

  let hz = 100 + (total * 8);

  document.getElementById("freqContainer").innerHTML = `

    <div class="result">

      <h2>Sua Frequência Atual</h2>

      <h1>${hz} Hz</h1>

      <p>
      Sua frequência energética demonstra o nível atual
      de equilíbrio emocional, mental e espiritual.
      </p>

      <p>
      Para elevar ainda mais:
      </p>

      <ul>
        <li>Pratique meditação</li>
        <li>Evite pensamentos negativos</li>
        <li>Durma melhor</li>
        <li>Fortaleça sua espiritualidade</li>
        <li>Pratique gratidão diariamente</li>
      </ul>

      <canvas id="grafico" width="500" height="250"></canvas>

    </div>
  `;

  desenharGrafico(hz);
}

function desenharGrafico(hz){

  const canvas = document.getElementById("grafico");
  const ctx = canvas.getContext("2d");

  ctx.fillStyle = "#6a11cb";

  ctx.fillRect(50,200-hz/3,100,hz/3);

  ctx.font = "20px Arial";
  ctx.fillText(hz + " Hz", 60, 220);
}

mostrarPerguntaFreq();

</script>

</body>
</html>

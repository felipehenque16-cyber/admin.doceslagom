];

const ARQS = {
  heroi:    { nome: 'O Herói',    desc: 'Você é movido por uma força interior que não aceita estagnação. O Herói não é necessariamente aquele que não tem medo — é aquele que age apesar do medo, que escolhe se mover quando seria mais fácil recuar. Há em você uma energia transformadora que se manifesta na disposição de enfrentar o que é difícil, de ir além do que outros julgam possível, de superar versões anteriores de si mesmo em ciclos contínuos de crescimento. Sua presença inspira porque as pessoas sentem, intuitivamente, que estão diante de alguém que não desiste. O Herói carrega, porém, um desafio que poucos falam: a necessidade de aprender que força verdadeira também inclui a vulnerabilidade de pedir ajuda, de reconhecer os próprios limites e de entender que descanso não é fraqueza — é a preparação para o próximo movimento.' },
  sabio:    { nome: 'O Sábio',    desc: 'Você habita o mundo de uma forma diferente da maioria: com uma necessidade quase visceral de entender — não apenas os fatos, mas o porquê por trás dos fatos, as conexões invisíveis que dão sentido ao aparente caos da existência. O Sábio não se satisfaz com respostas superficiais. Para você, uma conversa real é aquela que vai fundo, que questiona os próprios pilares, que não tem medo de chegar a incertezas maiores do que as que existiam antes. Há em você uma forma de ver o mundo que é ao mesmo tempo analítica e intuitiva — você percebe padrões, reconhece arquétipos, decifra dinâmicas que outros mal percebem. O desafio do Sábio é lembrar que o conhecimento mais profundo não vive apenas nos livros ou nas análises — ele também mora nas experiências vividas no corpo, nas emoções sentidas sem julgamento, nos momentos de não saber.' },
  cuidador: { nome: 'O Cuidador', desc: 'Seu coração tem uma capacidade de expansão que poucos possuem. O Cuidador não cuida por obrigação ou por medo de desapontar — cuida porque genuinamente encontra sentido e alegria em ser o espaço seguro para quem está ao redor. Há em você uma presença que as pessoas sentem antes de você dizer uma palavra: algo que comunica "aqui é um lugar seguro, aqui você pode ser como é". Você tem o dom de perceber o que o outro precisa muitas vezes antes que ele mesmo articule, e uma habilidade quase instintiva de criar condições para que as pessoas ao seu redor floresçam. O desafio do Cuidador — e é um desafio real, não apenas retórico — é aprender que as suas necessidades também importam, que seus limites são sagrados, e que uma versão sua esgotada e invisível a si mesma não consegue dar ao mundo o melhor que tem a oferecer.' },
  mago:     { nome: 'O Mago',     desc: 'Você enxerga o que ainda não existe como se já fosse real. O Mago opera no espaço entre a intenção e a manifestação — aquela zona onde as coisas ainda são possibilidades mas já carregam a semente do que estão prestes a se tornar. Você tem uma capacidade de transformar realidades que vai além do técnico ou do estratégico: é uma força que emerge da combinação de intuição elevada, criatividade genuína e uma fé profunda no poder da intenção consciente. Quando você está em pleno alinhamento com o seu propósito, há algo quase alquímico no que você cria — situações que pareciam impossíveis se reorganizam, pessoas certas aparecem, recursos surgem de formas que a lógica linear não consegue explicar. O desafio do Mago é ancorar esse poder em ação consistente — porque visão sem prática é apenas imaginação.' },
};

let idxA = 0, respA = [];

function renderArqu() {
  const c = document.getElementById('quizContainer');
  if (!c) return;
  if (idxA >= PERGS_ARQU.length) { finalizarArqu(); return; }

  const dots = PERGS_ARQU.map((_, i) =>
    `<span class="dot ${i < idxA ? 'done' : i === idxA ? 'current' : ''}"></span>`
  ).join('');

  c.innerHTML = `
    <div class="quiz-dots">${dots}</div>
    <div class="question-card">
      <div class="question-num">Pergunta ${idxA + 1} de ${PERGS_ARQU.length}</div>
      <div class="question-text">${PERGS_ARQU[idxA]}</div>
      <button class="opt-btn" onclick="respA_fn('A')">Sim, muito característico</button>
      <button class="opt-btn" onclick="respA_fn('B')">Às vezes, depende do contexto</button>
      <button class="opt-btn" onclick="respA_fn('C')">Não, pouco característico</button>
    </div>`;
}

window.respA_fn = function (r) { respA.push(r); idxA++; renderArqu(); };

function finalizarArqu() {
  const w = { A: 3, B: 2, C: 1 };
  const sc = { heroi: 0, sabio: 0, cuidador: 0, mago: 0 };

  sc.heroi    += w[respA[0]] || 0;                                            // Q0  liderança
  if (respA[1] === 'A') sc.mago += 3; else if (respA[1] === 'C') sc.sabio += 3; else { sc.mago++; sc.sabio++; } // Q1 emoção
  sc.heroi    += w[respA[2]] || 0;                                            // Q2  aventura
  sc.heroi    += Math.max(0, (w[respA[3]] || 0) - 1);                        // Q3  reconhecimento
  sc.cuidador += w[respA[4]] || 0;                                            // Q4  estabilidade
  sc.mago     += w[respA[5]] || 0;                                            // Q5  criatividade
  sc.cuidador += w[respA[6]] || 0;                                            // Q6  ajudar
  sc.heroi    += Math.max(0, (w[respA[7]] || 0) - 1);                        // Q7  decisão rápida
  sc.sabio    += w[respA[8]] || 0;                                            // Q8  reservado
  sc.mago     += w[respA[9]] || 0;                                            // Q9  sonha grande

  const sorted = Object.entries(sc).sort((a, b) => b[1] - a[1]);
  const [p, s] = sorted;

  document.getElementById('quizContainer').innerHTML = `
    <div class="result-card">
      <div class="result-card-title">Seus Arquétipos Revelados</div>
      <div class="arch-card">
        <div class="arch-name">${ARQS[p[0]].nome} <span class="arch-badge">Principal</span></div>
        <div class="arch-desc">${ARQS[p[0]].desc}</div>
      </div>
      <div class="arch-card">
        <div class="arch-name">${ARQS[s[0]].nome} <span class="arch-badge">Secundário</span></div>
        <div class="arch-desc">${ARQS[s[0]].desc}</div>
      </div>
      <div class="arch-card" style="border-color:rgba(196,160,68,.22)">
        <div class="arch-name" style="font-size:16px;color:var(--text-muted)">A Combinação dos Seus Arquétipos</div>
        <div class="arch-desc">Nenhum ser humano é habitado por um único arquétipo — somos constelações de forças em constante diálogo. O arquétipo principal é aquele que domina a forma como você age no mundo, como você enfrenta desafios e como os outros instintivamente te percebem. O arquétipo secundário é a sua camada de profundidade: ele aparece nas relações mais íntimas, nos momentos de crise genuína, nas escolhas que você faz quando ninguém está olhando. Compreender como essas duas forças interagem dentro de você é um dos exercícios mais ricos do autoconhecimento — porque é nessa interface que vivem seus maiores potenciais e também seus desafios mais recorrentes.</div>
      </div>
      <div class="reset-row">
        <button class="btn btn-ghost" onclick="resetArqu()">Refazer Quiz</button>
      </div>
    </div>`;
  toast('Arquétipos revelados!');
}

function resetArqu() { idxA = 0; respA = []; renderArqu(); }
renderArqu();

/* ═══════════════════════════════════════
   FREQUENCY QUIZ
═══════════════════════════════════════ */
const PERGS_FREQ = [
  'Com qual frequência você experimenta um estado de paz interior genuíno — não a ausência de problemas, mas uma serenidade que existe como fundo constante, mesmo quando a vida está em pleno movimento ao redor?',
  'Você reserva momentos deliberados e regulares de silêncio, meditação ou quietude para se reconectar com o que está dentro de você — não apenas quando está esgotado, mas como prática preventiva de cuidado com a própria alma?',
  'Quando emoções intensas surgem — raiva, medo, tristeza, ansiedade — você consegue atravessá-las sem se perder nelas, sem agir impulsivamente a partir delas, retornando ao seu centro com relativa serenidade depois da tempestade?',
  'A gratidão é uma prática real e consciente na sua vida — algo que vai além de um pensamento ocasional de "tenho sorte" e se manifesta como uma forma genuína de enxergar e honrar o que existe de bom, mesmo nos dias difíceis?',
  'Seu sono te restaura de verdade? Você costuma acordar sentindo que seu corpo e sua mente estiveram em descanso profundo — não apenas desligados, mas verdadeiramente renovados para um novo dia?',
  'Você se sente verdadeiramente vivo e com energia vital no dia a dia — não apenas funcionando no piloto automático, mas presente, motivado e com um senso real de que o que você faz tem propósito e significado?',
  'Quando surgem conflitos, mal-entendidos ou situações de atrito com outras pessoas, você consegue lidar com eles sem guardar ressentimento prolongado e sem sair desses encontros completamente drenado de energia?',
  'Você mantém uma conexão viva e consciente com o mundo natural — com a terra, com o céu, com os ciclos das estações, com algo que existe além das telas, dos espaços fechados e do ritmo frenético da vida urbana?',
];

let idxF = 0, respF = [];

function renderFreq() {
  const c = document.getElementById('freqContainer');
  if (!c) return;
  if (idxF >= PERGS_FREQ.length) { finalizarFreq(); return; }

  const dots = PERGS_FREQ.map((_, i) =>
    `<span class="dot ${i < idxF ? 'done' : i === idxF ? 'current' : ''}"></span>`
  ).join('');

  c.innerHTML = `
    <div class="quiz-dots">${dots}</div>
    <div class="question-card">
      <div class="question-num">Questão ${idxF + 1} de ${PERGS_FREQ.length}</div>
      <div class="question-text">${PERGS_FREQ[idxF]}</div>
      <button class="opt-btn" onclick="respF_fn(4)">Sempre</button>
      <button class="opt-btn" onclick="respF_fn(3)">Frequentemente</button>
      <button class="opt-btn" onclick="respF_fn(2)">Raramente</button>
      <button class="opt-btn" onclick="respF_fn(1)">Nunca</button>
    </div>`;
}

window.respF_fn = function (v) { respF.push(v); idxF++; renderFreq(); };

function finalizarFreq() {
  const total = respF.reduce((a, b) => a + b, 0);
  const pct   = total / (PERGS_FREQ.length * 4);
  const hz    = Math.round(50 + pct * 200);

  let nivel, cor, interp;
  if      (hz >= 210) { nivel = 'Alta Vibração';              cor = '#c4a044'; interp = 'Você está em um dos estados mais elevados de sintonia espiritual que uma pessoa pode alcançar no cotidiano. Sua frequência não é acidente — é o resultado acumulado de escolhas conscientes, práticas consistentes e uma disposição genuína de olhar para dentro com honestidade. Neste estado, sua energia irradia de forma que afeta positivamente tudo e todos ao seu redor: você atrai experiências de crescimento genuíno, relações que nutrem, oportunidades que se alinham com seu propósito mais profundo. Há uma leveza na forma como você atravessa os desafios — não porque eles inexistem, mas porque você desenvolveu a capacidade de não se fundir com eles. A sua presença neste momento é um presente para o campo coletivo. Mantenha as práticas que te trouxeram até aqui e permita-se também celebrar este nível de alinhamento — você construiu algo real.'; }
  else if (hz >= 165) { nivel = 'Boa Frequência';             cor = '#7a9bd4'; interp = 'Sua energia está em um bom patamar de equilíbrio e expansão contínua. Você não está no ápice, mas está claramente em movimento ascendente — e isso, na jornada espiritual, é frequentemente mais valioso do que chegar ao topo de uma vez. Você demonstra consistência nas práticas que nutrem seu bem-estar, e isso se traduz em uma base energética estável sobre a qual você pode continuar construindo. Há uma maturidade crescente na forma como você lida com seus estados internos — uma capacidade de observar sem ser arrastado, de sentir sem se perder, de agir sem reagir. Continue cultivando as práticas que te trouxeram até aqui. O próximo nível de vibração não requer grandes revoluções — requer a continuidade e o aprofundamento do que você já está fazendo com intenção.'; }
  else if (hz >= 120) { nivel = 'Frequência em Expansão';     cor = '#a87fc4'; interp = 'Existe em você uma energia que quer crescer, expandir, se elevar — e também há algumas áreas onde padrões antigos ainda exercem uma influência que talvez você já esteja começando a reconhecer. Este é um ponto muito importante da jornada: você está num limiar. Não no início, não no ápice, mas naquele espaço fértil onde pequenas mudanças consistentes têm o poder de criar transformações internas que redefinem toda a trajetória. As sementes que você plantar agora em termos de práticas, hábitos de atenção e cuidado com sua energia vão florescer de formas que hoje podem parecer improváveis. Não subestime o impacto de um pequeno gesto diário de presença — de cinco minutos de silêncio, de uma refeição consciente, de uma conversa honesta consigo mesmo antes de dormir.'; }
  else                { nivel = 'Frequência em Reconstrução'; cor = '#c48888'; interp = 'Este resultado não é um julgamento — é uma leitura honesta de um momento que, para quem está disposto a ouvi-lo, carrega um convite poderoso. Você está numa fase de reconstrução, e reconstrução é um dos processos mais sagrados que existem: é quando o que não servia mais foi removido e há espaço, finalmente, para que algo mais verdadeiro tome forma. Neste momento, cada ato de cuidado consigo mesmo é um ato espiritual de primeira grandeza. Não precisa ser grandioso — precisa ser real. Beber água com atenção. Respirar fundo antes de reagir. Dormir cedo um dia. Dizer não a algo que drena. São esses gestos que, acumulados com gentileza e sem pressa, reconstroem uma frequência sólida e duradoura. Você chegou até aqui. Isso já é evidência de força.'; }

  const ARC_LEN = Math.PI * 90;
  const finalOffset = (ARC_LEN * (1 - pct)).toFixed(2);

  const cx = 130, cy = 120, r = 90;

  document.getElementById('freqContainer').innerHTML = `
    <div class="result-card">
      <div class="gauge-wrap">
        <svg class="gauge-svg" viewBox="0 0 260 132" fill="none" xmlns="http://www.w3.org/2000/svg" aria-label="Medidor de frequência: ${hz} Hz">
          <path class="gauge-track" d="M 40 120 A 90 90 0 0 0 220 120"
                stroke="rgba(255,255,255,.06)" stroke-width="14" stroke-linecap="round" fill="none"/>
          <path class="gauge-fill" d="M 40 120 A 90 90 0 0 0 220 120"
                stroke="${cor}" stroke-width="14" stroke-linecap="round" fill="none"
                style="filter:drop-shadow(0 0 6px ${cor}55); --final:${finalOffset}"/>
          <text x="130" y="104" text-anchor="middle"
                font-family="Cormorant Garamond, serif" font-size="46" fill="${cor}" font-weight="300">${hz}</text>
          <text x="130" y="120" text-anchor="middle"
                font-family="DM Sans, sans-serif" font-size="11" fill="rgba(242,234,204,.38)" letter-spacing="2">Hz</text>
        </svg>
        <div class="gauge-level" style="color:${cor}">${nivel}</div>
      </div>

      <div class="result-row">
        <strong>Interpretação</strong>
        <p>${interp}</p>
      </div>

      <div class="result-row">
        <strong>Para elevar e sustentar sua frequência</strong>
      </div>

      <ul class="tips-list">
        <li class="tip-item">Medite 10 a 20 minutos ao amanhecer — antes de checar o celular, antes de falar com alguém, antes de qualquer ruído externo. Esse momento é seu.</li>
        <li class="tip-item">Pratique gratidão com intenção antes de dormir — não uma lista automática, mas a lembrança genuína de um momento do dia que merece ser honrado.</li>
        <li class="tip-item">Tome sol matinal por pelo menos 15 minutos com os pés descalços na terra, se possível. O corpo vibra diferente quando reconhece os ritmos naturais.</li>
        <li class="tip-item">Conecte-se com a natureza semanalmente de forma consciente — uma caminhada, um jardim, o céu estrelado. O mundo natural recalibra o que o ambiente artificial desregula.</li>
        <li class="tip-item">Escute música em 528 Hz ou 432 Hz durante atividades cotidianas — essas frequências sonoras têm efeito documentado sobre o sistema nervoso e o estado emocional.</li>
      </ul>

      <div class="reset-row" style="margin-top:24px">
        <button class="btn btn-ghost" onclick="resetFreq()">Refazer Avaliação</button>
      </div>
    </div>`;

  /* animate gauge fill */
  requestAnimationFrame(() => requestAnimationFrame(() => {
    const fill = document.querySelector('.gauge-fill');
    if (fill) fill.style.strokeDashoffset = finalOffset;
  }));

  toast(`Sua frequência: ${hz} Hz — ${nivel}`);
}

function resetFreq() { idxF = 0; respF = []; renderFreq(); }
renderFreq();
</script>
</body>
</html>
